.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--mat-sys-surface-container);
  border-bottom: 1px solid var(--mat-sys-outline-variant);
  padding: 0 24px;
  height: 64px;
  min-height: 64px;

  &__left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  &__greeting {
    font-size: 16px;
    font-weight: 600;
    color: var(--mat-sys-on-surface);
  }

  &__date {
    font-size: 12px;
    color: var(--mat-sys-on-surface-variant);
  }

  &__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  &__participants {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  &__participants-label {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--mat-sys-on-surface-variant);
  }

  &__online-icon {
    font-size: 10px;
    width: 10px;
    height: 10px;
    color: #4caf50;
  }

  &__avatars {
    display: flex;
    align-items: center;
  }

  &__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--mat-sys-surface-container);
    margin-left: -6px;
    object-fit: cover;

    &:first-child {
      margin-left: 0;
    }

    &--offline {
      filter: grayscale(80%);
      opacity: 0.6;
    }

    &--more {
      background: var(--mat-sys-secondary-container);
      color: var(--mat-sys-on-secondary-container);
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
}
