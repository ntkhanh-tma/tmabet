<mat-toolbar class="header">
  <div class="header__left">
    <span class="header__greeting">{{ greeting }}, Champion! ⚽</span>
    <span class="header__date">{{ currentDate | date: 'EEEE, MMMM d, y' }}</span>
  </div>

  <div class="header__right">
    <div class="header__participants">
      <span class="header__participants-label">
        <mat-icon class="header__online-icon">circle</mat-icon>
        {{ onlineCount }} online
      </span>
      <div class="header__avatars">
        @for (participant of participants.slice(0, 5); track participant.name) {
          <img
            class="header__avatar"
            [src]="participant.avatarUrl"
            [alt]="participant.name"
            [matTooltip]="participant.name"
            [class.header__avatar--offline]="!participant.isOnline"
          />
        }
        @if (participants.length > 5) {
          <div class="header__avatar header__avatar--more">
            +{{ participants.length - 5 }}
          </div>
        }
      </div>
    </div>

    <button mat-icon-button matTooltip="Notifications">
      <mat-icon [matBadge]="'3'" matBadgeColor="warn" matBadgeSize="small">notifications</mat-icon>
    </button>

    <button mat-icon-button matTooltip="Refresh data">
      <mat-icon>refresh</mat-icon>
    </button>
  </div>
</mat-toolbar>
