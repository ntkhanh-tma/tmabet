.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--mat-sys-surface-container);
  border-bottom: 1px solid var(--mat-sys-outline-variant);
  padding: 0 24px;
  height: 64px;
  min-height: 64px;

  &__left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  &__greeting {
    font-size: 16px;
    font-weight: 600;
    color: var(--mat-sys-on-surface);
  }

  &__date {
    font-size: 12px;
    color: var(--mat-sys-on-surface-variant);
  }

  &__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  &__addicts-label {
    font-size: 13px;
    color: var(--mat-sys-on-surface-variant);
  }
}
