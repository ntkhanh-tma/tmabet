<div class="dashboard">
  @if (loading) {
    <div class="dashboard__loading">
      <mat-progress-bar mode="indeterminate"></mat-progress-bar>
      <p>Loading dashboard data…</p>
    </div>
  }

  @if (data) {
    <div class="dashboard__grid">

      <!-- ── Zone 1: Featuring Matches ───────────────────────────────────── -->
      <mat-card class="dashboard__card dashboard__card--full-row">
        <mat-card-header>
          <mat-icon mat-card-avatar>sports_soccer</mat-icon>
          <mat-card-title>Featuring Matches</mat-card-title>
          <mat-card-subtitle>Upcoming &amp; live fixtures</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <div class="matches-grid">
            @for (match of data.featuringMatches; track match.id) {
              <div class="match-card" [style.background-color]="match.groupColor">
                <div class="match-card__header">
                  <mat-chip [highlighted]="match.status === 'live'" [color]="getStatusColor(match.status)">
                    @if (match.status === 'live') {
                      <mat-icon>fiber_manual_record</mat-icon>
                    }
                    {{ match.status | uppercase }}
                  </mat-chip>
                  <span class="match-card__group">{{ match.group }}</span>
                </div>

                <div class="match-card__teams">
                  <div class="match-card__team">
                    <span class="fi fi-{{ match.homeFlag }} match-card__flag"></span>
                    <span class="match-card__team-name">{{ match.homeTeam }}</span>
                  </div>

                  <div class="match-card__score">
                    @if (match.status !== 'upcoming') {
                      <span class="match-card__score-value">
                        {{ match.homeScore }} – {{ match.awayScore }}
                      </span>
                    } @else {
                      <span class="match-card__vs">VS</span>
                    }
                  </div>

                  <div class="match-card__team match-card__team--away">
                    <span class="fi fi-{{ match.awayFlag }} match-card__flag"></span>
                    <span class="match-card__team-name">{{ match.awayTeam }}</span>
                  </div>
                </div>

                  <div class="match-card__meta">
                    <mat-icon class="match-card__meta-icon">schedule</mat-icon>
                    <span>{{ match.matchDate | date: 'MMM d' }} · {{ match.matchTime }}</span>
                  </div>
              </div>
            }
          </div>
        </mat-card-content>
      </mat-card>

      <!-- ── Zone 2: Leaderboard ──────────────────────────────────────────── -->
      <mat-card class="dashboard__card">
        <mat-card-header>
          <mat-icon mat-card-avatar>leaderboard</mat-icon>
          <mat-card-title>Leaderboard</mat-card-title>
          <mat-card-subtitle>Top {{ data.leaderboard.length }} players</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <div class="leaderboard">
            @for (entry of data.leaderboard; track entry.rank) {
              <div class="leaderboard__row" [class.leaderboard__row--top3]="entry.rank <= 3">
                <div class="leaderboard__rank">
                  @if (entry.rank === 1) { 🥇 }
                  @else if (entry.rank === 2) { 🥈 }
                  @else if (entry.rank === 3) { 🥉 }
                  @else { {{ entry.rank }} }
                </div>
                <div class="leaderboard__info">
                  <span class="leaderboard__name">{{ entry.playerName }}</span>
                  <mat-progress-bar
                    mode="determinate"
                    [value]="(entry.totalPoints / getMaxPoints()) * 100"
                    class="leaderboard__bar"
                  ></mat-progress-bar>
                </div>
                <div class="leaderboard__points">
                  <span class="leaderboard__pts">{{ entry.totalPoints }}</span>
                  <span class="leaderboard__pts-label">pts</span>
                </div>
              </div>
            }
          </div>
        </mat-card-content>
      </mat-card>

      <!-- ── Zone 3: Current Bet Matches ────────────────────────────────── -->
      <mat-card class="dashboard__card">
        <mat-card-header>
          <mat-icon mat-card-avatar>how_to_vote</mat-icon>
          <mat-card-title>Open for Bets</mat-card-title>
          <mat-card-subtitle>Current matches &amp; bet counts</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <div class="bet-matches">
            @for (m of data.currentBetMatches; track m.homeTeam) {
              <div class="bet-match">
                <div class="bet-match__team">
                  <span class="fi fi-{{ m.homeFlag }} bet-match__flag"></span>
                  <span class="bet-match__name">{{ m.homeTeam }}</span>
                  <span class="bet-match__count">{{ m.homeBets }}</span>
                </div>
                <span class="bet-match__vs">VS</span>
                <div class="bet-match__team bet-match__team--right">
                  <span class="bet-match__count">{{ m.awayBets }}</span>
                  <span class="bet-match__name">{{ m.awayTeam }}</span>
                  <span class="fi fi-{{ m.awayFlag }} bet-match__flag"></span>
                </div>
              </div>
            }
            @if (data.currentBetMatches.length === 0) {
              <p class="bet-matches__empty">No matches currently open for betting.</p>
            }
          </div>
        </mat-card-content>
      </mat-card>

      <!-- ── Zone 4: Current Bets Table ──────────────────────────────────── -->
      <mat-card class="dashboard__card dashboard__card--full-row">
        <mat-card-header>
          <mat-icon mat-card-avatar>casino</mat-icon>
          <mat-card-title>Current Bets</mat-card-title>
          <mat-card-subtitle>{{ data.bets.length }} bets placed</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          @if (data.currentBetMatches[0] || data.currentBetMatches[1]) {
            <table mat-table [dataSource]="data.bets" class="bets-table">

              <ng-container matColumnDef="player">
                <th mat-header-cell *matHeaderCellDef>Player</th>
                <td mat-cell *matCellDef="let bet">{{ bet.playerName }}</td>
              </ng-container>

              <ng-container matColumnDef="match1">
                <th mat-header-cell *matHeaderCellDef>
                  @if (data.currentBetMatches[0]) {
                    <span class="fi fi-{{ data.currentBetMatches[0].homeFlag }} bets-table__flag"></span>
                    {{ data.currentBetMatches[0].homeTeam }}
                    vs
                    {{ data.currentBetMatches[0].awayTeam }}
                    <span class="fi fi-{{ data.currentBetMatches[0].awayFlag }} bets-table__flag"></span>
                  } @else {
                    Match 1
                  }
                </th>
                <td mat-cell *matCellDef="let bet">
                  @if (bet.match1Bet) {
                    <span class="bet-chip" [class.bet-chip--home]="bet.match1Bet === data.currentBetMatches[0]?.homeTeam">
                      <span class="fi fi-{{ getFlag(bet.match1Bet) }} bets-table__flag"></span>
                      {{ bet.match1Bet }}
                    </span>
                  } @else {
                    <span class="bets-table__empty">–</span>
                  }
                </td>
              </ng-container>

              <ng-container matColumnDef="match2">
                <th mat-header-cell *matHeaderCellDef>
                  @if (data.currentBetMatches[1]) {
                    <span class="fi fi-{{ data.currentBetMatches[1].homeFlag }} bets-table__flag"></span>
                    {{ data.currentBetMatches[1].homeTeam }}
                    vs
                    {{ data.currentBetMatches[1].awayTeam }}
                    <span class="fi fi-{{ data.currentBetMatches[1].awayFlag }} bets-table__flag"></span>
                  } @else {
                    Match 2
                  }
                </th>
                <td mat-cell *matCellDef="let bet">
                  @if (bet.match2Bet) {
                    <span class="bet-chip" [class.bet-chip--home]="bet.match2Bet === data.currentBetMatches[1]?.homeTeam">
                      <span class="fi fi-{{ getFlag(bet.match2Bet) }} bets-table__flag"></span>
                      {{ bet.match2Bet }}
                    </span>
                  } @else {
                    <span class="bets-table__empty">–</span>
                  }
                </td>
              </ng-container>

              <ng-container matColumnDef="modifier">
                <th mat-header-cell *matHeaderCellDef>Modifier</th>
                <td mat-cell *matCellDef="let bet">
                  @if (bet.modifier) {
                    <span class="bet-modifier">{{ bet.modifier }}</span>
                  } @else {
                    <span class="bets-table__empty">–</span>
                  }
                </td>
              </ng-container>

              <tr mat-header-row *matHeaderRowDef="['player','match1','match2','modifier']"></tr>
              <tr mat-row *matRowDef="let row; columns: ['player','match1','match2','modifier']"></tr>
            </table>
          }
        </mat-card-content>
      </mat-card>

    </div>
  }
</div>
