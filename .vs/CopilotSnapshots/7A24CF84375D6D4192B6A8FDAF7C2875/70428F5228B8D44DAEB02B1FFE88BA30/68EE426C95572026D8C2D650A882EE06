@use "@angular/material" as mat;

// -- Custom World Cup dark palette --------------------------------------------
// Primary: Deep gold (trophy gold)
// Secondary: Grass green (pitch)
// Tertiary: Sky blue

html {
  @include mat.theme((
    color: (
      theme-type: dark,
      primary: mat.$yellow-palette,
      secondary: mat.$green-palette,
      tertiary: mat.$cyan-palette,
    ),
    typography: Roboto,
    density: 0,
  ));
}

html, body {
  height: 100%;
  margin: 0;
}

body {
  color-scheme: dark;
  background-color: var(--mat-sys-surface);
  color: var(--mat-sys-on-surface);
  font-family: Roboto, "Helvetica Neue", sans-serif;
  font: var(--mat-sys-body-medium);
}

// -- Scrollbar styling ---------------------------------------------------------
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: var(--mat-sys-surface-container);
}
::-webkit-scrollbar-thumb {
  background: var(--mat-sys-outline);
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--mat-sys-primary);
}

// -- mat-table dark overrides ---------------------------------------------------
.mat-mdc-table {
  background: transparent !important;
}
.mat-mdc-header-row {
  background: var(--mat-sys-surface-container) !important;
}
.mat-mdc-row:hover {
  background: var(--mat-sys-surface-container-high) !important;
}

// -- mat-card overrides --------------------------------------------------------
.mat-mdc-card {
  --mdc-elevated-card-container-color: var(--mat-sys-surface-container-low);
}

// -- mat-chip live pulse -------------------------------------------------------
mat-chip[color="warn"] mat-icon {
  animation: pulse 1s infinite;
  color: var(--mat-sys-error);
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.3; }
}
