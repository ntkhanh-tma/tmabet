<div class="dashboard">
  @if (loading) {
    <div class="dashboard__loading">
      <mat-progress-bar mode="indeterminate"></mat-progress-bar>
      <p>Loading dashboard data…</p>
    </div>
  }

  @if (data) {
    <div class="dashboard__grid">

      <!-- ── Zone 1: Featuring Matches ───────────────────────────────────── -->
      <mat-card class="dashboard__card dashboard__card--full-row">
        <mat-card-header>
          <mat-icon mat-card-avatar>sports_soccer</mat-icon>
          <mat-card-title>Featuring Matches</mat-card-title>
          <mat-card-subtitle>Upcoming &amp; live fixtures</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <div class="matches-grid">
            @for (match of data.featuringMatches; track match.id) {
              <div class="match-card">
                <div class="match-card__header">
                  <mat-chip [highlighted]="match.status === 'live'" [color]="getStatusColor(match.status)">
                    @if (match.status === 'live') {
                      <mat-icon>fiber_manual_record</mat-icon>
                    }
                    {{ match.status | uppercase }}
                  </mat-chip>
                  <span class="match-card__group">{{ match.group }}</span>
                </div>

                <div class="match-card__teams">
                    <div class="match-card__team">
                      <span class="fi fi-{{ match.homeFlag }} match-card__flag"></span>
                      <span class="match-card__team-name">{{ match.homeTeam }}</span>
                    </div>

                    <div class="match-card__score">
                      @if (match.status !== 'upcoming') {
                        <span class="match-card__score-value">
                          {{ match.homeScore }} – {{ match.awayScore }}
                        </span>
                      } @else {
                        <span class="match-card__vs">VS</span>
                      }
                    </div>

                    <div class="match-card__team match-card__team--away">
                      <span class="fi fi-{{ match.awayFlag }} match-card__flag"></span>
                      <span class="match-card__team-name">{{ match.awayTeam }}</span>
                    </div>
                  </div>

                  <div class="match-card__meta">
                    <mat-icon class="match-card__meta-icon">schedule</mat-icon>
                    <span>{{ match.matchDate | date: 'MMM d' }} · {{ match.matchTime }}</span>
                  </div>
              </div>
            }
          </div>
        </mat-card-content>
      </mat-card>

      <!-- ── Zone 2: Leaderboard ──────────────────────────────────────────── -->
      <mat-card class="dashboard__card">
        <mat-card-header>
          <mat-icon mat-card-avatar>leaderboard</mat-icon>
          <mat-card-title>Leaderboard</mat-card-title>
          <mat-card-subtitle>Top {{ data.leaderboard.length }} players</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <div class="leaderboard">
            @for (entry of data.leaderboard; track entry.rank) {
              <div class="leaderboard__row" [class.leaderboard__row--top3]="entry.rank <= 3">
                <div class="leaderboard__rank">
                  @if (entry.rank === 1) { 🥇 }
                  @else if (entry.rank === 2) { 🥈 }
                  @else if (entry.rank === 3) { 🥉 }
                  @else { {{ entry.rank }} }
                </div>
                <img class="leaderboard__avatar" [src]="entry.avatarUrl" [alt]="entry.playerName" />
                <div class="leaderboard__info">
                  <span class="leaderboard__name">{{ entry.playerName }}</span>
                  <mat-progress-bar
                    mode="determinate"
                    [value]="(entry.totalPoints / getMaxPoints()) * 100"
                    class="leaderboard__bar"
                  ></mat-progress-bar>
                </div>
                <div class="leaderboard__points">
                  <span class="leaderboard__pts">{{ entry.totalPoints }}</span>
                  <span class="leaderboard__pts-label">pts</span>
                </div>
              </div>
            }
          </div>
        </mat-card-content>
      </mat-card>

      <!-- ── Zone 3: Recent Results ───────────────────────────────────────── -->
      <mat-card class="dashboard__card">
        <mat-card-header>
          <mat-icon mat-card-avatar>emoji_events</mat-icon>
          <mat-card-title>Recent Results</mat-card-title>
          <mat-card-subtitle>Latest finished matches</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <div class="results-list">
            @for (result of data.recentResults; track result.matchId) {
              <div class="result-row">
                <div class="result-row__teams">
                  <span class="result-row__flag">{{ result.homeFlag }}</span>
                  <span class="result-row__team">{{ result.homeTeam }}</span>
                </div>
                <div class="result-row__score">
                  {{ result.homeScore }} – {{ result.awayScore }}
                </div>
                <div class="result-row__teams result-row__teams--right">
                  <span class="result-row__team">{{ result.awayTeam }}</span>
                  <span class="result-row__flag">{{ result.awayFlag }}</span>
                </div>
                <div class="result-row__meta">
                  <span class="result-row__date">{{ result.matchDate | date: 'MMM d' }}</span>
                  <span class="result-row__group">{{ result.group }}</span>
                </div>
              </div>
              <mat-divider></mat-divider>
            }
          </div>
        </mat-card-content>
      </mat-card>

      <!-- ── Zone 4: Recent Bet History ──────────────────────────────────── -->
      <mat-card class="dashboard__card dashboard__card--full-row">
        <mat-card-header>
          <mat-icon mat-card-avatar>casino</mat-icon>
          <mat-card-title>Recent Bet History</mat-card-title>
          <mat-card-subtitle>Latest player predictions</mat-card-subtitle>
        </mat-card-header>
        <mat-card-content>
          <table mat-table [dataSource]="data.recentBets" class="bets-table">

            <ng-container matColumnDef="status">
              <th mat-header-cell *matHeaderCellDef>Result</th>
              <td mat-cell *matCellDef="let bet">
                <mat-icon [class]="getBetStatusClass(bet.status)" [matTooltip]="bet.status | titlecase">
                  {{ getBetStatusIcon(bet.status) }}
                </mat-icon>
              </td>
            </ng-container>

            <ng-container matColumnDef="player">
              <th mat-header-cell *matHeaderCellDef>Player</th>
              <td mat-cell *matCellDef="let bet">{{ bet.playerName }}</td>
            </ng-container>

            <ng-container matColumnDef="match">
              <th mat-header-cell *matHeaderCellDef>Match</th>
              <td mat-cell *matCellDef="let bet">
                {{ bet.homeFlag }} {{ bet.homeTeam }} vs {{ bet.awayTeam }} {{ bet.awayFlag }}
              </td>
            </ng-container>

            <ng-container matColumnDef="prediction">
              <th mat-header-cell *matHeaderCellDef>Prediction</th>
              <td mat-cell *matCellDef="let bet">
                {{ bet.predictedHomeScore }} – {{ bet.predictedAwayScore }}
              </td>
            </ng-container>

            <ng-container matColumnDef="actual">
              <th mat-header-cell *matHeaderCellDef>Actual</th>
              <td mat-cell *matCellDef="let bet">
                @if (bet.actualHomeScore !== undefined) {
                  {{ bet.actualHomeScore }} – {{ bet.actualAwayScore }}
                } @else {
                  <span class="bets-table__pending">–</span>
                }
              </td>
            </ng-container>

            <ng-container matColumnDef="points">
              <th mat-header-cell *matHeaderCellDef>Pts</th>
              <td mat-cell *matCellDef="let bet">
                @if (bet.points !== undefined) {
                  <span class="bets-table__points" [class.bets-table__points--zero]="bet.points === 0">
                    {{ bet.points }}
                  </span>
                } @else {
                  <span class="bets-table__pending">–</span>
                }
              </td>
            </ng-container>

            <ng-container matColumnDef="date">
              <th mat-header-cell *matHeaderCellDef>Date</th>
              <td mat-cell *matCellDef="let bet">{{ bet.betDate | date: 'MMM d' }}</td>
            </ng-container>

            <tr mat-header-row *matHeaderRowDef="['status','player','match','prediction','actual','points','date']"></tr>
            <tr mat-row *matRowDef="let row; columns: ['status','player','match','prediction','actual','points','date']"></tr>
          </table>
        </mat-card-content>
      </mat-card>

    </div>
  }
</div>
