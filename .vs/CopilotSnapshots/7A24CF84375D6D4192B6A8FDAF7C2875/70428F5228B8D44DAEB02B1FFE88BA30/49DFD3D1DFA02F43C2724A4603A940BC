export interface Match {
  id: string;
  homeTeam: string;
  awayTeam: string;
  /** ISO 3166-1 alpha-2 code used with flag-icons */
  homeFlag: string;
  /** ISO 3166-1 alpha-2 code used with flag-icons */
  awayFlag: string;
  matchDate: string;
  matchTime: string;
  group: string;
  groupColor: string;
  homeScore?: number;
  awayScore?: number;
  status: 'upcoming' | 'live' | 'finished';
}

/** Raw row shape from matches.json (column names match the sheet headers) */
export interface SheetMatch {
  Date: string;
  Time: string;
  HomeTeam: string;
  AwayTeam: string;
  HomeScore: string;
  AwayScore: string;
  Group: string;
  Stage: string;
}

/** Matches grouped by calendar date for the Matches page */
export interface MatchDay {
  date: string;
  matches: Match[];
}

export interface LeaderboardEntry {
  rank: number;
  playerName: string;
  avatarUrl: string;
  totalPoints: number;
  correctScores: number;
  correctOutcomes: number;
  totalBets: number;
}

export interface MatchResult {
  matchId: string;
  homeTeam: string;
  awayTeam: string;
  homeFlag: string;
  awayFlag: string;
  homeScore: number;
  awayScore: number;
  matchDate: string;
  group: string;
}

export interface BetEntry {
  id: string;
  playerName: string;
  homeTeam: string;
  awayTeam: string;
  homeFlag: string;
  awayFlag: string;
  predictedHomeScore: number;
  predictedAwayScore: number;
  actualHomeScore?: number;
  actualAwayScore?: number;
  points?: number;
  betDate: string;
  status: 'pending' | 'won' | 'lost' | 'partial';
}

export interface DashboardData {
  featuringMatches: Match[];
  leaderboard: LeaderboardEntry[];
  recentResults: MatchResult[];
  recentBets: BetEntry[];
}

export interface Participant {
  name: string;
  avatarUrl: string;
  isOnline: boolean;
}
