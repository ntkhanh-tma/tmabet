.dashboard {
  padding: 24px;
  height: 100%;
  box-sizing: border-box;
  overflow-y: auto;

  &__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48px;
    gap: 16px;
    color: var(--mat-sys-on-surface-variant);
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  &__card {
    background: var(--mat-sys-surface-container-low);

    &--full-row {
      grid-column: 1 / -1;
    }

    mat-card-avatar {
      background: var(--mat-sys-primary-container);
      color: var(--mat-sys-on-primary-container);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
    }
  }
}

// ── Featuring Matches ──────────────────────────────────────────────────────────

.matches-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
  margin-top: 8px;
}

.match-card {
  background: var(--mat-sys-surface-container);
  border-radius: 12px;
  padding: 16px;
  border: 1px solid var(--mat-sys-outline-variant);

  &__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  &__group {
    font-size: 11px;
    color: var(--mat-sys-on-surface-variant);
    font-weight: 600;
  }

  &__teams {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  &__team {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;

    &--away {
      align-items: flex-end;
    }
  }

  &__flag {
    width: 32px;
    height: 24px;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }

  &__team-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--mat-sys-on-surface);
    text-align: center;
  }

  &__score {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 60px;
  }

  &__score-value {
    font-size: 22px;
    font-weight: 700;
    color: var(--mat-sys-primary);
  }

  &__vs {
    font-size: 14px;
    font-weight: 700;
    color: var(--mat-sys-outline);
  }

  &__meta {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--mat-sys-on-surface-variant);
  }

  &__meta-icon {
    font-size: 14px;
    width: 14px;
    height: 14px;
  }
}

// ── Leaderboard ────────────────────────────────────────────────────────────────

.leaderboard {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 8px;

  &__row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border-radius: 8px;
    background: var(--mat-sys-surface-container);

    &--top3 {
      background: var(--mat-sys-secondary-container);
    }
  }

  &__rank {
    width: 28px;
    text-align: center;
    font-size: 16px;
    font-weight: 700;
    color: var(--mat-sys-on-surface-variant);
    flex-shrink: 0;
  }

  &__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  &__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  &__name {
    font-size: 13px;
    font-weight: 600;
    color: var(--mat-sys-on-surface);
  }

  &__bar {
    height: 4px;
    border-radius: 2px;
  }

  &__points {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  &__pts {
    font-size: 16px;
    font-weight: 700;
    color: var(--mat-sys-primary);
  }

  &__pts-label {
    font-size: 10px;
    color: var(--mat-sys-on-surface-variant);
  }
}

// ── Recent Results ─────────────────────────────────────────────────────────────

.results-list {
  margin-top: 8px;
}

.result-row {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto;
  align-items: center;
  gap: 8px;
  padding: 10px 4px;

  &__teams {
    display: flex;
    align-items: center;
    gap: 6px;

    &--right {
      justify-content: flex-end;
    }
  }

  &__flag {
    width: 22px;
    height: 16px;
    border-radius: 2px;
    vertical-align: middle;
  }

  &__team {
    font-size: 13px;
    font-weight: 600;
    color: var(--mat-sys-on-surface);
  }

  &__score {
    font-size: 16px;
    font-weight: 700;
    color: var(--mat-sys-primary);
    background: var(--mat-sys-surface-container);
    padding: 4px 10px;
    border-radius: 8px;
    min-width: 52px;
    text-align: center;
  }

  &__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  &__date {
    font-size: 11px;
    color: var(--mat-sys-on-surface-variant);
  }

  &__group {
    font-size: 10px;
    color: var(--mat-sys-outline);
  }
}

// ── Bet History Table ──────────────────────────────────────────────────────────

.bets-table {
  width: 100%;
  margin-top: 8px;

  &__pending {
    color: var(--mat-sys-outline);
  }

  &__points {
    font-weight: 700;
    color: var(--mat-sys-primary);

    &--zero {
      color: var(--mat-sys-error);
    }
  }

  &__flag {
    width: 18px;
    height: 13px;
    border-radius: 2px;
    vertical-align: middle;
  }
}

.bet-status--won {
  color: #4caf50;
}

.bet-status--lost {
  color: var(--mat-sys-error);
}

.bet-status--partial {
  color: #ff9800;
}

.bet-status--pending {
  color: var(--mat-sys-on-surface-variant);
}
